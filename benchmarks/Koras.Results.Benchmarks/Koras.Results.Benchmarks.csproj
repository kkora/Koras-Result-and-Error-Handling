<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <!-- BenchmarkDotNet manages its own build configuration concerns. -->
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- CA1707: benchmark names use underscores, matching test naming style. -->
    <NoWarn>$(NoWarn);CS1591;CA1822;CA1707</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Koras.Results/Koras.Results.csproj" />
  </ItemGroup>

</Project>
