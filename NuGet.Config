<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Single, explicit source: supply-chain hygiene. Local feeds are added per-machine, never committed. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
